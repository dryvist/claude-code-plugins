{
  // markdownlint-cli2 does not read .markdownlintignore (cli v1 only), so the
  // ignore list lives here where the org gate's cli2 action honors it.
  "config": {
    "extends": "./.markdownlint.json"
  },
  "ignores": [
    // gh-aw compiled imports (generated, vendored verbatim — not editable)
    ".github/aw/imports/**",
    // Auto-generated by release-please; duplicate headings are intentional
    "CHANGELOG.md",
    "node_modules/**"
  ]
}
