{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "include-v-in-tag": true,
      "changelog-sections": [
        {"type": "feat", "section": "Features"},
        {"type": "fix", "section": "Bug Fixes"},
        {"type": "perf", "section": "Performance"},
        {"type": "breaking", "section": "Breaking Changes"},
        {"type": "chore", "section": "Miscellaneous", "hidden": true},
        {"type": "ci", "section": "CI", "hidden": true},
        {"type": "docs", "section": "Documentation", "hidden": true},
        {"type": "refactor", "section": "Refactoring", "hidden": true},
        {"type": "test", "section": "Tests", "hidden": true}
      ],
      "version-file": "VERSION",
      "extra-files": [
        {"type": "json", "path": "ai-delegation/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "code-standards/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "codeql-resolver/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "config-management/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "content-guards/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "git-guards/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "git-standards/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "git-workflows/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "github-workflows/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "infra-orchestration/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "infra-standards/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "pal-health/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "pr-lifecycle/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "process-cleanup/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "project-standards/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "script-guards/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {"type": "json", "path": "session-analytics/.claude-plugin/plugin.json", "jsonpath": "$.version"},
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[*].version"
        },
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.metadata.version"
        }
      ]
    }
  }
}
